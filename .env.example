# ─── Base de datos PostgreSQL ───────────────────────────────────────────────
# Para producción usa Neon (neon.tech) o Supabase — ambos proveen estas dos URLs.
# DATABASE_URL  → URL con connection pooler (puerto 6543 en Neon)
# DIRECT_URL    → URL directa sin pooler (puerto 5432) — requerida por Prisma migrate
DATABASE_URL="postgresql://usuario:password@localhost:5432/certidocs"
DIRECT_URL="postgresql://usuario:password@localhost:5432/certidocs"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Genera el secret con: openssl rand -base64 32
NEXTAUTH_SECRET="genera-un-secret-seguro-con-openssl-rand-base64-32"
# En producción: https://certidocs-xi.vercel.app (sin barra final)
NEXTAUTH_URL="http://localhost:3000"

# ─── Supabase ──────────────────────────────────────────────────────────────
# Obtener en: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://tu-proyecto.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key"

# ─── Sentry (Monitoreo) ──────────────────────────────────────────────────────
# Obtener en: https://sentry.io/settings/projects/tu-proyecto/keys/
SENTRY_DSN="https://tu-dsn@sentry.io/project-id"

# Price IDs de los planes (crear en dashboard.stripe.com > Products > Pricing)
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_ENTERPRISE="price_..."

# ─── Resend (email) ───────────────────────────────────────────────────────────
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY="re_..."
# Dominio verificado en Resend — en desarrollo puedes usar onboarding@resend.dev
EMAIL_FROM="CertiDocs <noreply@certidocs.es>"
# Email donde llegan las notificaciones de nuevos encargos
ADMIN_EMAIL="info@certidocs.es"

# ─── Cron jobs ────────────────────────────────────────────────────────────────
# Genera con: openssl rand -base64 32
# Vercel añade automáticamente Authorization: Bearer <CRON_SECRET> en las llamadas de cron
CRON_SECRET="tu-secret-seguro-aqui"

# ─── Automatización Playwright ────────────────────────────────────────────────
# URL al tarball de Chromium para Vercel Lambda (usa @sparticuz/chromium-min).
# En local déjalo vacío — se usa el Chromium de @playwright/test.
# En producción Vercel: apunta al release de GitHub que coincide con la versión instalada.
# Versión actual del paquete: @sparticuz/chromium-min@147 → usa v131 del tarball.
CHROMIUM_REMOTE_EXEC_PATH="https://github.com/Sparticuz/chromium/releases/download/v131.0.0/chromium-v131.0.0-pack.tar"

# Pon "true" para testing local sin enviar formularios al Ministerio de Justicia
AUTOMATION_DRY_RUN="false"

# ─── Vercel Blob (adjuntos de solicitudes) ───────────────────────────────────
# Crear en: vercel.com → proyecto → Storage → Blob → Create store
# El token se obtiene automáticamente al enlazar el store al proyecto en Vercel.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ─── Datos fiscales del emisor (para facturas PDF) ───────────────────────────
EMPRESA_NOMBRE="CertiDocs SL"
EMPRESA_NIF="B12345678"
EMPRESA_DIRECCION="Via Laietana 59, 4.º 1.ª, 08003 Barcelona"
EMPRESA_EMAIL="soporte@certidocs.es"

# ─── Autenticación Cl@ve Permanente (opcional) ───────────────────────────────
# NIF del operador registrado en Cl@ve Permanente (usuario de la empresa gestora)
CLAVEPIN_USER=""
# Contraseña de Cl@ve Permanente
CLAVEPIN_PASS=""
# Seed TOTP en base32 — se obtiene al activar 2FA en Cl@ve: "No puedo escanear el QR"
CLAVEPIN_TOTP_SECRET=""

# ─── Certificado digital FNMT (alternativa al Cl@ve) ─────────────────────────
# Archivo .p12 exportado del navegador, codificado en base64:
#   base64 -i mi_certificado.p12 | tr -d '\n'
CERT_P12_BASE64=""
# Contraseña del archivo .p12
CERT_P12_PASSWORD=""

# ─── DNI electrónico con lector de tarjetas (solo on-premise) ────────────────
# ATENCIÓN: el DNIe requiere hardware físico — NO funciona en Vercel/Railway.
# Solo para servidores locales o VPS con lector USB conectado.
#
# Paso 1: instalar el middleware DNIe:
#   Windows → https://www.dnielectronico.es/PortalDNIe/ (instala automáticamente en almacén Windows)
#   Linux   → apt install opensc pcscd; systemctl start pcscd
#   macOS   → brew install opensc; brew install pcsc-lite
#
# Paso 2: configurar estas variables y reiniciar el servidor
DNIE_ENABLED="false"          # Cambiar a "true" para activar
DNIE_PIN=""                   # PIN de la tarjeta (para autocompletar si el middleware usa JS prompt)
# Solo Linux/macOS — ruta a la librería PKCS#11 del middleware:
DNIE_PKCS11_LIB=""            # p.ej. /usr/lib/x86_64-linux-gnu/opensc-pkcs11.so
