{
  "framework": "nextjs",
  "buildCommand": "prisma generate && prisma migrate deploy && next build",
  "installCommand": "npm ci",
  "regions": ["fra1"],
  "functions": {
    "src/app/api/cron/automatizacion/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/pagos/webhook/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    { "path": "/api/cron/recordatorios",          "schedule": "0 10 * * *"    },
    { "path": "/api/cron/automatizacion",         "schedule": "0 9 * * *"     },
    { "path": "/api/cron/health-check",           "schedule": "0 12 * * *"    },
    { "path": "/api/cron/seguimiento-tramitados", "schedule": "0 8 * * *"     },
    { "path": "/api/cron/limpiar-abandonadas",    "schedule": "0 3 * * *"     },
    { "path": "/api/cron/reintentar-webhooks",    "schedule": "0 7 * * *"     }
  ]
}
